generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#00ff88")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
}

model Chat {
  id        String    @id @default(cuid())
  name      String    @default("New chat")
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
}

model Message {
  id          String   @id @default(cuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String
  content     String
  attachments Json?
  status      String   @default("done")
  createdAt   DateTime @default(now())

  @@index([chatId])
}

model Todo {
  id        String    @id @default(cuid())
  text      String
  done      Boolean   @default(false)
  projectId String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String       @id @default(cuid())
  name        String
  searchQuery String?
  maxPrice    Float?
  category    String       @default("gpu")
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  prices      PriceEntry[]
}

model PriceEntry {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  retailer  String
  country   String
  price     Float
  currency  String   @default("EUR")
  inStock   Boolean  @default(false)
  url       String
  scrapedAt DateTime @default(now())

  @@index([productId])
  @@index([scrapedAt])
}

model GPU {
  id           String    @id @default(cuid())
  model        String
  supplier     String
  serialNumber String    @unique
  purchaseDate DateTime?
  cost         Float?
  status       String    @default("In Stock")
  boxId        String?
  box          Box?      @relation(fields: [boxId], references: [id])
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([boxId])
  @@index([status])
}

model Box {
  id          String   @id @default(cuid())
  name        String
  destination String?
  status      String   @default("Packing")
  notes       String?
  gpus        GPU[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Run {
  id        String    @id @default(cuid())
  title     String
  status    String    @default("pending")
  model     String    @default("ollama/qwen2.5:7b")
  steps     RunStep[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model RunStep {
  id             String   @id @default(cuid())
  runId          String
  run            Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  order          Int
  prompt         String
  result         String   @default("")
  status         String   @default("pending")
  model          String?
  retries        Int      @default(0)
  maxRetries     Int      @default(2)
  requiresReview Boolean  @default(false)
  approved       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([runId])
}

model Credit {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  model     String
  totalCost Float
  timeframe String   @default("daily")
  source    String   @default("openclaw")
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, model, source])
  @@index([date])
  @@index([source])
}

// ── Order Management ──────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  company   String?
  
  // Address fields
  addressLine1 String?
  addressLine2 String?
  city      String?
  state     String?
  postalCode String?
  country   String   @default("NL")
  
  // Metadata
  notes     String?
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([active])
  @@index([createdAt])
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique // e.g., ORD-2026-001
  
  // Customer info
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  
  // Order status
  status      String   @default("pending") // pending, confirmed, shipped, delivered, cancelled
  paymentStatus String  @default("unpaid") // unpaid, paid, refunded
  
  // Order items
  items       OrderItem[]
  
  // Pricing
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  shipping    Float    @default(0)
  total       Float    @default(0)
  currency    String   @default("EUR")
  
  // Dates
  orderDate   DateTime @default(now())
  dueDate     DateTime?
  shippedDate DateTime?
  deliveryDate DateTime?
  
  // Additional info
  shippingMethod String? // e.g., "express", "standard"
  trackingNumber String?
  notes       String?
  internalNotes String?
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderDate])
  @@index([dueDate])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Product info
  productName String
  sku         String?
  quantity    Int
  unitPrice   Float
  total       Float // quantity * unitPrice
  
  // Product details (denormalized for easy viewing)
  productCategory String?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([sku])
}
